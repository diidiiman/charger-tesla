{
  "expo": {
    "name": "Tesla Charger",
    "slug": "teslacharger",
    "scheme": "teslacharger",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/ios-icon.png",
      "supportsTablet": false,
      "bundleIdentifier": "com.clankersystems.charging"
    },
    "android": {
      "package": "com.clankersystems.charging",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a0a0c"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "extra": {
      "apiBase": "${EXPO_PUBLIC_API_BASE}",
      "router": {},
      "eas": {
        "projectId": "2cd8315b-9bbe-46db-942e-23854a5cc48e"
      }
    }
  }
}
