{
	email {$ACME_EMAIL}
}

{$PUBLIC_DOMAIN} {
	encode zstd gzip

	# All API + OAuth callbacks go to the FastAPI backend.
	# Caddy auto-provisions a Let's Encrypt cert for {$PUBLIC_DOMAIN}
	# on first start, then renews it automatically.
	reverse_proxy backend:8000

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}
