{
  "host": "0.0.0.0",
  "port": 4443,
  "log_level": "info",
  "json_log_enable": true,
  "transmit_decoded_records": true,
  "records": {
    "alerts": ["mqtt"],
    "errors": ["mqtt"],
    "V": ["mqtt"],
    "connectivity": ["mqtt"]
  },
  "mqtt": {
    "broker": "mqtt:1883",
    "client_id": "fleet-telemetry-server",
    "topic_base": "telemetry",
    "qos": 1,
    "retained": false
  },
  "tls": {
    "server_cert": "/etc/fleet-telemetry/certs/server.crt",
    "server_key": "/etc/fleet-telemetry/certs/server.key"
  }
}
