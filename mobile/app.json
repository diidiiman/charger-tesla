{
  "expo": {
    "name": "Tesla Nord Pool",
    "slug": "teslacharger",
    "scheme": "teslacharger",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/ios-icon.png",
      "supportsTablet": false,
      "bundleIdentifier": "com.clankersystems.charging"
    },
    "android": {
      "package": "com.clankersystems.charging",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a0a0c"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-web-browser",
      "react-native-iap",
      "./plugins/withProguardRules.js",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "kotlinVersion": "2.2.0"
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "tesla-nord-pool",
          "organization": "clanker-systems"
        }
      ]
    ],
    "extra": {
      "apiBase": "${EXPO_PUBLIC_API_BASE}",
      "router": {},
      "eas": {
        "projectId": "2cd8315b-9bbe-46db-942e-23854a5cc48e"
      }
    }
  }
}
